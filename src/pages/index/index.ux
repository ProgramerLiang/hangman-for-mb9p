<template>
  <div class="page">
    <text class="clock">{{ clock }}</text>
    <text class="title">HANGMAN</text>

    <!-- === MENU === -->
    <div class="main" if="{{screen === 'menu'}}">
      <div class="card menu-card">
        <text class="subtitle-text">猜单词游戏</text>
        <text class="highscore-text">最高分 {{highScore}}</text>
      </div>
      <input class="btn-start" type="button" value="开始游戏" style="background-color: {{accentColor}}" onclick="onStartGame" />
      <input class="btn-settings" type="button" value="设置" onclick="onOpenSettings" />
      <input class="btn-about" type="button" value="关于" onclick="onOpenAbout" />

    <!-- === SETTINGS === -->
    <div class="main" if="{{screen === 'settings'}}">
      <text class="settings-heading">主题色</text>
      <div class="color-grid">
        <div class="swatch {{accentColor === '#e94560' ? 'swatch-on' : ''}}" style="background-color: #e94560" onclick="onPickColor('#e94560')"></div>
        <div class="swatch {{accentColor === '#0f3460' ? 'swatch-on' : ''}}" style="background-color: #0f3460" onclick="onPickColor('#0f3460')"></div>
        <div class="swatch {{accentColor === '#16c79a' ? 'swatch-on' : ''}}" style="background-color: #16c79a" onclick="onPickColor('#16c79a')"></div>
        <div class="swatch {{accentColor === '#f5a623' ? 'swatch-on' : ''}}" style="background-color: #f5a623" onclick="onPickColor('#f5a623')"></div>
      </div>
      <div class="color-grid" style="margin-top: 0;">
        <div class="swatch {{accentColor === '#8b5cf6' ? 'swatch-on' : ''}}" style="background-color: #8b5cf6" onclick="onPickColor('#8b5cf6')"></div>
        <div class="swatch {{accentColor === '#ec4899' ? 'swatch-on' : ''}}" style="background-color: #ec4899" onclick="onPickColor('#ec4899')"></div>
        <div class="swatch {{accentColor === '#06b6d4' ? 'swatch-on' : ''}}" style="background-color: #06b6d4" onclick="onPickColor('#06b6d4')"></div>
        <div class="swatch {{accentColor === '#84cc16' ? 'swatch-on' : ''}}" style="background-color: #84cc16" onclick="onPickColor('#84cc16')"></div>
      </div>
      <text class="settings-heading" style="margin-top: 18px;">振动反馈</text>
      <div class="setting-row">
        <text class="setting-label">按键振动</text>
        <switch checked="{{vibrationOn}}" class="vib-switch" @change="onVibChange"></switch>
      </div>
      <input class="btn-start" type="button" value="返回" style="background-color: {{accentColor}}" onclick="onGoMenu" />
    </div>

    <!-- === ABOUT === -->
    <div class="main" if="{{screen === 'about'}}">
      <div class="about-card">
        <text class="about-title">Hangman 猜单词</text>
        <text class="about-ver">v{{versionName}} ({{versionCode}})</text>
        <text class="about-sep"></text>
        <text class="about-text">Developed by Corripo</text>
        <text class="about-sub">由 DeepSeek V4 Pro 强力辅助</text>
        <text class="about-sep"></text>
        <text class="about-tech">aiot-toolkit 2.0.5</text>
        <text class="about-tech">Node v24.17.0 · Linux x64</text>
      </div>
      <input class="btn-start" type="button" value="返回" style="background-color: {{accentColor}}" onclick="onGoMenu" />
    </div>

    <!-- === PLAYING === -->
    <div class="main" if="{{screen === 'playing'}}">
      <div class="card word-card">
        <text class="word-display" style="color: {{accentColor}}">{{wordDisplay}}</text>
      </div>
      <text class="status-text">错误 {{wrongCount}}/{{maxWrong}}</text>
      <text class="hint-text" if="{{showHint}}">{{currentHint}}</text>
      <div class="card art-card">
        <text class="hangman-art" style="color: {{accentColor}}">{{hangmanArt}}</text>
      </div>
    </div>

    <!-- === RESULT === -->
    <div class="main" if="{{screen === 'result'}}">
      <div class="card result-card">
        <text class="result-title" style="color: {{accentColor}}">{{resultTitle}}</text>
        <text class="result-word">单词：{{secretWord}}</text>
        <text class="result-hint">{{currentHint}}</text>
        <text class="result-score-text" if="{{streak > 0}}">连胜 {{streak}} 局 · 得分 {{score}}</text>
      </div>
      <input class="btn-start" type="button" value="再来一局" style="background-color: {{accentColor}}" onclick="onStartGame" />
      <input class="btn-menu" type="button" value="返回菜单" onclick="onGoMenu" />
    </div>

    <!-- === KEYBOARD === -->
    <div class="keyboard-area" show="{{screen === 'playing' && !win && wrongCount < maxWrong}}">
      <scroll scroll-x="true" style="width: 100%; height: 190px;">
        <div style="flex-direction: column; width: 640px; align-items: center;">
          <div class="key-row">
            <text for="{{keyRow1}}" class="key {{$item.disabled ? 'key-disabled' : ''}}" style="border-color: {{accentColor}}44" onclick="onKeyClick($item,0,$idx)">{{$item.char}}</text>
          </div>
          <div class="key-row" style="margin-left: 34px;">
            <text for="{{keyRow2}}" class="key {{$item.disabled ? 'key-disabled' : ''}}" style="border-color: {{accentColor}}44" onclick="onKeyClick($item,1,$idx)">{{$item.char}}</text>
          </div>
          <div class="key-row" style="margin-left: 74px;">
            <text for="{{keyRow3}}" class="key {{$item.disabled ? 'key-disabled' : ''}}" style="border-color: {{accentColor}}44" onclick="onKeyClick($item,2,$idx)">{{$item.char}}</text>
          </div>
        </div>
      </scroll>
    </div>
  </div>
</template>

<style>
  .page { width: 336px; height: 480px; color: #ffffff; background-color: #000000; flex-direction: column; }
  .clock { position: absolute; left: 77px; top: 7px; width: 182px; height: 34px; font-size: 26px; color: #9a9a9a; text-align: center; }
  .title { position: absolute; left: 77px; top: 35px; width: 182px; height: 45px; font-size: 28px; color: #ffffff; text-align: center; }
  .main { position: absolute; top: 82px; left: 6px; width: 324px; height: 398px; flex-direction: column; align-items: center; }
  .menu-card { margin-top: 50px; margin-bottom: 16px; }
  .word-card { margin-top: 10px; margin-bottom: 4px; }
  .art-card { margin-top: 6px; margin-bottom: 4px; }
  .result-card { margin-top: 30px; margin-bottom: 16px; align-items: center; }
  .subtitle-text { font-size: 24px; color: #ffffff; lines: 1; width: 260px; text-align: center; }
  .highscore-text { font-size: 20px; color: #9a9a9a; lines: 1; margin-top: 8px; width: 260px; text-align: center; }
  .word-display { font-size: 32px; font-weight: bold; lines: 1; text-align: center; }
  .hint-text { font-size: 24px; color: #f0a500; lines: 2; text-align: center; width: 300px; margin-top: 6px; }
  .hangman-art { font-size: 18px; lines: 4; text-align: center; }
  .status-text { position: absolute; right: 10px; top: 10px; font-size: 18px; color: #9a9a9a; lines: 1; }
  .result-title { font-size: 34px; font-weight: bold; lines: 1; margin-bottom: 6px; text-align: center; color: #ffffff; width: 260px; }
  .result-word { font-size: 24px; color: #ffffff; lines: 1; margin-bottom: 4px; text-align: center; width: 260px; }
  .result-hint { font-size: 22px; color: #a8a8a8; lines: 2; margin-bottom: 4px; text-align: center; width: 260px; }
  .result-score-text { font-size: 20px; color: #f0a500; lines: 1; text-align: center; width: 260px; }
  .btn-start { width: 220px; height: 56px; font-size: 24px; color: #ffffff; border-radius: 28px; margin-top: 12px; }
  .btn-settings { width: 220px; height: 50px; font-size: 22px; color: #a8a8a8; background-color: #262626; border-radius: 28px; margin-top: 10px; }
  .btn-about { width: 220px; height: 50px; font-size: 22px; color: #a8a8a8; background-color: #262626; border-radius: 28px; margin-top: 10px; }
  .btn-menu { width: 220px; height: 50px; font-size: 22px; color: #a8a8a8; background-color: #262626; border-radius: 28px; margin-top: 10px; }
  .keyboard-area { position: absolute; left: 0; bottom: 4px; width: 100%; }
  .key-row { flex-direction: row; justify-content: flex-start; margin-top: 5px; }
  .key { width: 56px; height: 56px; margin: 3px; border-radius: 28px; background-color: #262626; border: 3px solid rgba(255,255,255,0.06); font-size: 22px; font-weight: bold; color: #ffffff; text-align: center; }
  .key-disabled { background-color: #1a1a1a; opacity: 0.3; }

  /* Settings */
  .settings-heading { font-size: 20px; color: #9a9a9a; lines: 1; margin-top: 8px; margin-bottom: 6px; width: 300px; text-align: left; }

  .color-grid { flex-direction: row; flex-wrap: wrap; width: 300px; justify-content: flex-start; }
  .swatch { width: 56px; height: 56px; border-radius: 28px; margin: 6px; border: 3px solid transparent; }
  .swatch-on { border-color: #ffffff; }
  .setting-row { flex-direction: row; width: 300px; justify-content: space-between; align-items: center; padding: 10px 0; }
  .setting-label { font-size: 22px; color: #ffffff; lines: 1; }
  .about-card { flex-direction: column; width: 300px; padding: 16px; border-radius: 20px; background-color: #262626; align-items: center; margin-top: 4px; }
  .about-title { font-size: 24px; font-weight: bold; color: #ffffff; lines: 1; }
  .about-ver { font-size: 18px; color: #9a9a9a; lines: 1; margin-top: 4px; }
  .about-sep { width: 200px; height: 1px; background-color: #3a3a3a; margin: 10px 0; }
  .about-text { font-size: 18px; color: #ffffff; lines: 1; }
  .about-sub { font-size: 16px; color: #a8a8a8; lines: 1; margin-top: 4px; }
  .about-tech { font-size: 16px; color: #6a6a6a; lines: 1; margin-top: 2px; }
</style>

<script>
  var hangman = require('../../common/hangman.js')
  var wordList = require('../../common/words.js')
  var storage = require('@system.storage')

  export default {
    private: {
      clock: '00:00',
      screen: 'menu',
      secretWord: '', wordDisplay: '', hangmanArt: '', currentHint: '',
      wrongCount: 0, maxWrong: 6, win: false, score: 0,
      showHint: true, resultTitle: '', highScore: 0, streak: 0,
      usedWords: [], guessedSet: '',
      keyRow1: [], keyRow2: [], keyRow3: [],
      accentColor: '#e94560',
      vibrationOn: true,
      versionName: '1.1.0',
      versionCode: 2,
      vib: null
    },

    onInit: function () {
      this._initKeys()
      this._loadPrefs()
      var s = this
      var n = new Date()
      this.clock = s._p(n.getHours()) + ':' + s._p(n.getMinutes())
      setInterval(function () {
        var d = new Date()
        s.clock = s._p(d.getHours()) + ':' + s._p(d.getMinutes())
      }, 1000)
      this.loadHighScore()
      try { this.vib = require('@system.vibrator') } catch (e) { this.vib = null }
    },

    _initKeys: function () {
      this.keyRow1 = ['Q','W','E','R','T','Y','U','I','O','P'].map(function(c) { return { char: c, disabled: false } })
      this.keyRow2 = ['A','S','D','F','G','H','J','K','L'].map(function(c) { return { char: c, disabled: false } })
      this.keyRow3 = ['Z','X','C','V','B','N','M'].map(function(c) { return { char: c, disabled: false } })
    },

    _p: function (a) { return a < 10 ? '0' + a : '' + a },

    _loadPrefs: function () {
      var s = this
      try {
        storage.get({ key: 'hangman_accent', success: function(d) { if (d && d.length > 0) s.accentColor = d }, fail: function() {} })
        storage.get({ key: 'hangman_vib', success: function(d) { s.vibrationOn = d !== '0' }, fail: function() {} })
      } catch (e) {}
    },

    _savePref: function (key, val) {
      try { storage.set({ key: key, value: String(val) }) } catch (e) {}
    },

    loadHighScore: function () {
      var s = this
      try {
        storage.get({ key: 'hangman_highscore', success: function(d) { if (d && d.length > 0) s.highScore = parseInt(d, 10) || 0 }, fail: function() { s.highScore = 0 } })
      } catch(e) { s.highScore = 0 }
    },

    saveHighScore: function () {
      try { storage.set({ key: 'hangman_highscore', value: String(this.highScore) }) } catch(e) {}
    },

    _doVib: function () {
      if (this.vibrationOn && this.vib) {
        try { this.vib.vibrate({ mode: 'short' }) } catch (e) {}
      }
    },

    /* === Navigation === */
    onOpenSettings: function () { this.screen = 'settings' },
    onOpenAbout: function () { this.screen = 'about' },
    onGoMenu: function () { this.screen = 'menu'; this.streak = 0 },

    /* === Game === */
    onStartGame: function () {
      this.guessedSet = ''; this._initKeys()
      var p = hangman.pickWord(wordList, this.usedWords)
      this.secretWord = p.word; this.wordDisplay = p.display; this.currentHint = p.hint
      this.wrongCount = 0; this.win = false; this.score = 0
      this.hangmanArt = hangman.getHangmanArt(0); this.showHint = true
      this.screen = 'playing'
    },

    onKeyClick: function (item) {
      if (this.win || this.wrongCount >= this.maxWrong || item.disabled) return
      item.disabled = true
      this.guessedSet = this.guessedSet + item.char
      this._doVib()
      var r = hangman.guessLetter(item.char, this.secretWord, this.wordDisplay)
      this.wordDisplay = r.display
      if (r.hit) {
        if (r.wordComplete) {
          this.win = true; this.streak = this.streak + 1; this.score = this.streak * 10
          if (this.score > this.highScore) { this.highScore = this.score; this.saveHighScore() }
          this.resultTitle = '恭喜过关！'
          var s = this
          setTimeout(function() { s.screen = 'result' }, 500)
        }
      } else {
        this.wrongCount++
        this.hangmanArt = hangman.getHangmanArt(this.wrongCount)
        if (this.wrongCount >= this.maxWrong) {
          this.win = false; this.streak = 0; this.score = 0
          this.wordDisplay = this.secretWord.split('').join(' ')
          this.resultTitle = '游戏结束'
          var s = this
          setTimeout(function() { s.screen = 'result' }, 500)
        }
      }
    },

    /* === Settings === */
    onPickColor: function (color) {
      this.accentColor = color
      this._savePref('hangman_accent', color)
    },

    onVibChange: function (e) {
      this.vibrationOn = e.checked
      this._savePref('hangman_vib', e.checked ? '1' : '0')
    }
  }
</script>